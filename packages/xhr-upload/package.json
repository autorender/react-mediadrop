{
	"name": "@mediadrop/xhr-upload",
	"private": true,
	"version": "0.1.0",
	"description": "Reference XMLHttpRequest transport adapter for react-mediadrop's pluggable upload queue.",
	"license": "MIT",
	"sideEffects": false,
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"size": "node ../../scripts/check-bundle-size.mjs"
	},
	"sizeLimit": {
		"dist/index.mjs": "3 KB"
	},
	"devDependencies": {
		"@mediadrop/core": "workspace:*",
		"@mediadrop/test-utils": "workspace:*",
		"@mediadrop/tsconfig": "workspace:*",
		"jsdom": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"tsdown": "catalog:"
	}
}
