{
	"name": "@mediadrop/react",
	"private": true,
	"version": "0.0.0",
	"description": "Headless React hook (useMediaDrop) for file intake, validation, and drag/drop over @mediadrop/core.",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"size": "node ../../scripts/check-bundle-size.mjs"
	},
	"sizeLimit": {
		"dist/index.mjs": "4 KB"
	},
	"peerDependencies": {
		"react": ">=18"
	},
	"dependencies": {
		"@mediadrop/core": "workspace:*"
	},
	"devDependencies": {
		"@mediadrop/tsconfig": "workspace:*",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"jsdom": "^29.1.1",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"typescript": "catalog:",
		"vitest": "^4.1.9",
		"tsdown": "^0.22.3"
	}
}
