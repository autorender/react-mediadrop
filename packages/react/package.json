{
	"name": "react-mediadrop",
	"private": true,
	"version": "0.0.0",
	"description": "Headless React hook (useMediaDrop) for file intake, validation, drag/drop, and upload — @mediadrop/core is bundled in, no separate install needed. The xhr-upload transport is a separate, tree-shakeable \"react-mediadrop/xhr-upload\" subpath.",
	"license": "MIT",
	"sideEffects": false,
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		},
		"./xhr-upload": {
			"types": "./dist/xhr-upload.d.mts",
			"default": "./dist/xhr-upload.mjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"size": "node ../../scripts/check-bundle-size.mjs"
	},
	"sizeLimit": {
		"dist/index.mjs": "10 KB",
		"dist/xhr-upload.mjs": "3 KB"
	},
	"peerDependencies": {
		"react": ">=18"
	},
	"devDependencies": {
		"@mediadrop/core": "workspace:*",
		"@mediadrop/xhr-upload": "workspace:*",
		"@mediadrop/tsconfig": "workspace:*",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"jsdom": "catalog:",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"typescript": "catalog:",
		"vitest": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"tsdown": "catalog:"
	}
}
