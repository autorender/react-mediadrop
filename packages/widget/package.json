{
	"name": "@mediadrop/widget",
	"private": true,
	"version": "0.0.0",
	"description": "An optional, lightweight, framework-neutral DOM widget over @mediadrop/core's public API. Headless mediadrop remains the core product — this is a convenience layer, not the foundation.",
	"license": "MIT",
	"sideEffects": [
		"*.css"
	],
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		},
		"./style.css": "./dist/style.css"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown && cp src/style.css dist/style.css",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"size": "node ../../scripts/check-bundle-size.mjs"
	},
	"sizeLimit": {
		"dist/index.mjs": "4 KB"
	},
	"dependencies": {
		"@mediadrop/core": "workspace:*"
	},
	"devDependencies": {
		"@mediadrop/tsconfig": "workspace:*",
		"jsdom": "^29.1.1",
		"typescript": "catalog:",
		"vitest": "^4.1.9",
		"tsdown": "^0.22.3"
	}
}
