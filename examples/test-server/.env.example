PORT=8787

# Required only for the S3 tabs. Leave unset to run xhr + tus only.
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
# Credentials: use the default AWS SDK chain (env vars below, a shared
# credentials file, or an assumed role) — not read directly by this app.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
