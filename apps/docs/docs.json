			},
			{
				"group": "Guides",
				"pages": [
					"guides/core-concepts",
					"guides/validation",
					"guides/upload",
					"guides/custom-transport"
				]
			},
			{
				"group": "API Reference",
				"pages": [
					"api-reference/use-media-drop",
					"api-reference/xhr-upload",
					"api-reference/types"
				]
			},
			{
				"group": "Project",
				"pages": ["contributing"]
			}
